# ============================================================
# AFRISTREAM — VARIABLES D'ENVIRONNEMENT
# Copie ce fichier en .env et remplis les vraies valeurs
# ============================================================

NODE_ENV=production
PORT=5000
FRONTEND_URL=https://kakaki-gif.github.io

# ── BASE DE DONNÉES ──
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/afristream

# ── JWT ──
JWT_SECRET=afristream_secret_2025_kakaki_change_moi

# ── CLOUDINARY (vidéos + images) ──
CLOUDINARY_CLOUD_NAME=ton_cloud_name
CLOUDINARY_API_KEY=ton_api_key
CLOUDINARY_API_SECRET=ton_api_secret

# ── COMMISSION PLATEFORME ──
PLATFORM_FEE=0.10
